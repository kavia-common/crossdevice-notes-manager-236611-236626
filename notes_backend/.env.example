# Notes backend environment variables

# DB connection (must match notes_db contract)
POSTGRES_URL=localhost
POSTGRES_PORT=5000
POSTGRES_DB=myapp
POSTGRES_USER=appuser
POSTGRES_PASSWORD=dbuser123

# JWT settings
# IMPORTANT: set JWT_SECRET to a strong random value in real deployments.
JWT_SECRET=change_me_to_a_long_random_secret
JWT_ISSUER=notes_backend
JWT_TTL_SECONDS=2592000
