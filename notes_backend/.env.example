# notes_backend environment variables (example)
#
# IMPORTANT:
# - Do not commit real secrets to the repo.
# - The runtime environment (.env) should provide these values.

# Required: JWT signing secret used for issuing/verifying tokens
JWT_SECRET=change-me-to-a-long-random-secret

# Optional: JWT issuer and TTL (seconds)
JWT_ISSUER=notes_backend
JWT_TTL_SECONDS=2592000

# Optional: CORS allowlist (comma-separated) or "*" for permissive dev
# CORS_ALLOW_ORIGINS=http://localhost:3000,https://your-frontend.example.com
CORS_ALLOW_ORIGINS=*

# Database connection contract (provided by notes_db container)
# Option A (recommended in this repo's contract): host + parts
POSTGRES_URL=localhost
POSTGRES_USER=appuser
POSTGRES_PASSWORD=dbpassword
POSTGRES_DB=myapp
POSTGRES_PORT=5000

# Option B (compatibility): full DSN (if your platform provides it this way)
# If POSTGRES_URL starts with postgres:// or postgresql://, backend uses it as-is.
# POSTGRES_URL=postgresql://appuser:dbpassword@localhost:5000/myapp
